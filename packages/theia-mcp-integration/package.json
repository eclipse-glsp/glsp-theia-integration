{
  "name": "@eclipse-glsp/theia-mcp-integration",
  "version": "2.8.0-next",
  "description": "Glue code to integrate GLSP MCP servers into Eclipse Theia",
  "keywords": [
    "theia-extension",
    "eclipse",
    "graphics",
    "diagram",
    "modeling",
    "visualization",
    "glsp",
    "diagram editor"
  ],
  "homepage": "https://www.eclipse.org/glsp/",
  "bugs": "https://github.com/eclipse-glsp/glsp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-glsp/glsp-theia-integration.git"
  },
  "license": "(EPL-2.0 OR GPL-2.0 WITH Classpath-exception-2.0)",
  "author": {
    "name": "Eclipse GLSP"
  },
  "contributors": [
    {
      "name": "Eclipse GLSP Project",
      "email": "glsp-dev@eclipse.org",
      "url": "https://projects.eclipse.org/projects/ecd.glsp"
    }
  ],
  "main": "lib/browser/index",
  "files": [
    "lib",
    "src",
    "css"
  ],
  "scripts": {
    "build": "pnpm compile",
    "clean": "rimraf lib *.tsbuildinfo ",
    "compile": "tsc -b",
    "generate:index": "glsp generateIndex src/browser -s -f",
    "lint": "eslint --ext .ts,.tsx ./src",
    "prepublishOnly": "pnpm build",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@eclipse-glsp/client": "next",
    "@eclipse-glsp/protocol": "next",
    "@eclipse-glsp/theia-integration": "workspace:*"
  },
  "peerDependencies": {
    "@theia/ai-mcp": "^1.66.0",
    "@theia/core": "^1.66.0",
    "reflect-metadata": "^0.2.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/theia-mcp-integration-frontend-module"
    }
  ]
}
