{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "[Theia] Compile browser app",
      "type": "shell",
      "group": "build",
      "command": "pnpm compile",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": ["$tsc", "$eslint-stylish"]
    },
    {
      "label": "[Theia] Watch all",
      "type": "shell",
      "group": "build",
      "command": "pnpm watch",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "[Theia] Start Workflow Theia Backend Example",
      "type": "shell",
      "group": "test",
      "command": "cd examples/browser-app && pnpm start",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "[Theia] Start Workflow Theia Backend Example (WebSocket Server)",
      "type": "shell",
      "group": "test",
      "command": "cd examples/browser-app && pnpm start:ws",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "[Theia] Start Workflow Theia Backend Example (DEBUG)",
      "type": "shell",
      "group": "test",
      "command": "cd examples/browser-app && pnpm start:debug",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "[Theia] Start Workflow Theia Backend Example (WebSocket Server) (DEBUG)",
      "type": "shell",
      "group": "test",
      "command": "cd examples/browser-app && pnpm start:ws:debug",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "[Theia] Download latest Workflow Example Java server",
      "type": "shell",
      "group": "test",
      "command": "pnpm download:exampleServer",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "[Theia] Link packages (local dev)",
      "detail": "Links all packages to the local source and shared dependencies",
      "type": "shell",
      "group": "none",
      "presentation": {
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "linux": {
        "command": "./configs/local-linking.sh",
        "args": ["${workspaceFolder}/../"]
      },
      "osx": {
        "command": "./configs/local-linking.sh",
        "args": ["${workspaceFolder}/../"]
      },
      "problemMatcher": []
    },
    {
      "label": "[Theia] Unlink packages (local dev)",
      "type": "shell",
      "group": "none",
      "presentation": {
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "linux": {
        "command": "./configs/local-linking.sh",
        "args": ["${workspaceFolder}/../", "--unlink"]
      },
      "osx": {
        "command": "./configs/local-linking.sh",
        "args": ["${workspaceFolder}/../", "--unlink"]
      },
      "problemMatcher": []
    },
    {
      "label": "[Theia] Open Workflow Theia example (Chrome)",
      "type": "shell",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "command": "google-chrome 127.0.0.1:3000"
    }
  ]
}
